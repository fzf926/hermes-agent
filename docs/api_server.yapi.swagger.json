    "/api/chat/users/{user_id}/sessions": {
      "get": {
        "tags": [
          "chat_history"
        ],
        "summary": "List chat sessions by user",
        "description": "Returns MySQL-stored sessions for a business user_id, ordered by updated_at descending (most recent first). Requires mysql_chat / HERMES_MYSQL_* to be enabled.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Business user identifier"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 20,
            "minimum": 1,
            "maximum": 100,
            "description": "Page size (default 20, max 100)"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 1,
            "minimum": 1,
            "description": "Page number (1-based)"
          }
        ],
        "responses": {
          "200": {
            "description": "Session list",
            "schema": {
              "$ref": "#/definitions/ChatUserSessionsResponse"
            },
            "examples": {
              "application/json": {
                "object": "list",
                "user_id": "10001",
                "total": 1,
                "limit": 20,
                "page": 1,
                "sessions": [
                  {
                    "id": 1,
                    "session_uid": "a1b2c3d4e5f6789012345678901234567",
                    "hermes_session_id": "sess_abc123",
                    "user_id": "10001",
                    "channel": "api_server",
                    "status": 1,
                    "turn_count": 3,
                    "last_question": "最近一条用户问题",
                    "started_at": "2026-05-17T10:00:00",
                    "updated_at": "2026-05-17T10:30:00"
                  }
                ]
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/OpenAIErrorEnvelope"
            }
          },
          "503": {
            "description": "MySQL chat store disabled or unavailable",
            "schema": {
              "$ref": "#/definitions/OpenAIErrorEnvelope"
            }
          }
        }
      }
    },
    "/api/chat/sessions/{session_id}/turns": {
      "get": {
        "tags": [
          "chat_history"
        ],
        "summary": "List Q&A turns by session",
        "description": "Returns Q&A turns for a session ordered by turn_no ascending (first turn at top). session_id may be the internal numeric id, session_uid, or hermes_session_id (X-Hermes-Session-Id).",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Internal id, session_uid, or hermes_session_id"
          }
        ],
        "responses": {
          "200": {
            "description": "Turn list",
            "schema": {
              "$ref": "#/definitions/ChatSessionTurnsResponse"
            },
            "examples": {
              "application/json": {
                "object": "list",
                "session": {
                  "id": 1,
                  "session_uid": "a1b2c3d4e5f6789012345678901234567",
                  "hermes_session_id": "sess_abc123",
                  "user_id": "10001",
                  "channel": "api_server"
                },
                "total": 2,
                "turns": [
                  {
                    "turn_no": 1,
                    "question_text": "你好",
                    "answer_text": "你好，我是 Hermes",
                    "status": "answered",
                    "created_at": "2026-05-17T10:00:01"
                  },
                  {
                    "turn_no": 2,
                    "question_text": "第二条问题",
                    "answer_text": "第二条回答",
                    "status": "answered",
                    "created_at": "2026-05-17T10:05:01"
                  }
                ]
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/OpenAIErrorEnvelope"
            }
          },
          "404": {
            "description": "Session not found",
            "schema": {
              "$ref": "#/definitions/OpenAIErrorEnvelope"
            }
          },
          "503": {
            "description": "MySQL chat store disabled or unavailable",
            "schema": {
              "$ref": "#/definitions/OpenAIErrorEnvelope"
            }
          }
        }
      }
    }

{
  "swagger": "2.0",
  "info": {
    "title": "Hermes SQL Favorites API",
    "description": "SQL 收藏接口。收藏符合条件的 chat_sql_execution：必须有 SQL，且每条 SQL 成功并在 5 秒内返回（query_time_ms <= 5000）。Q&A 仅存 AI 摘要。conversation_type=2 续聊后会更新 followup_hermes_session_id。来源: gateway/platforms/api_server.py + gateway/chat_mysql_store.py",
    "version": "1.0.0"
  },
  "host": "127.0.0.1:8642",
  "basePath": "/",
  "schemes": ["http"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Format: Bearer <API_SERVER_KEY>"
    }
  },
  "tags": [
    {
      "name": "sql_favorites",
      "description": "Bookmark satisfied chat turns with their SQL executions"
    }
  ],
  "paths": {
    "/api/chat/favorites": {
      "post": {
        "tags": ["sql_favorites"],
        "summary": "收藏一轮符合条件的 SQL",
        "description": "根据 hermes_response_id 定位 chat_message → chat_turn → chat_sql_execution，写入收藏表。hermes_response_id 兼容 /v1/responses 返回的 response.id、对话轮次接口返回的 hermes_response_id，以及 chat_message.id 主键；若传主键，后端会解析为对应的 chat_message.hermes_response_id 后再收藏。必须存在 SQL，且每条 SQL status=success、query_time_ms 非空并 <= 5000；同一 user_id + hermes_response_id 幂等（已存在返回 200）。创建时调用辅助 LLM 生成 question_summary / answer_summary，不存完整问答原文。",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "X-Hermes-User-Id",
            "in": "header",
            "required": false,
            "type": "string",
            "description": "业务用户 ID（也可在 body.user_id 传入）"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/CreateSqlFavoriteRequest"}
          }
        ],
        "responses": {
          "201": {
            "description": "新建收藏成功",
            "schema": {"$ref": "#/definitions/CreateSqlFavoriteResponse"},
            "examples": {
              "application/json": {
                "object": "chat.sql_favorite",
                "created": true,
                "favorite": {
                  "id": 1,
                  "favorite_uid": "a1b2c3d4e5f6789012345678901234567",
                  "user_id": "10001",
                  "session_id": 10,
                  "session_uid": "sess_uid_abc",
                  "hermes_session_id": "sess_hermes_abc",
                  "turn_id": 25,
                  "turn_no": 3,
                  "hermes_response_id": "resp_abc123",
                  "question_summary": "查询昨日订单总量",
                  "answer_summary": "返回按渠道汇总的订单数与金额",
                  "fulfillment_status": "satisfied",
                  "fulfillment_reason": "SQL 结果完整回答了用户问题",
                  "sql_count": 2,
                  "created_at": "2026-05-17T10:30:00",
                  "updated_at": "2026-05-17T10:30:00"
                }
              }
            }
          },
          "200": {
            "description": "已收藏过（幂等返回已有记录）",
            "schema": {"$ref": "#/definitions/CreateSqlFavoriteResponse"},
            "examples": {
              "application/json": {
                "object": "chat.sql_favorite",
                "created": false,
                "favorite": {
                  "id": 1,
                  "favorite_uid": "a1b2c3d4e5f6789012345678901234567",
                  "hermes_response_id": "resp_abc123",
                  "sql_count": 2
                }
              }
            }
          },
          "400": {
            "description": "非 satisfied、无 SQL、参数错误",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "401": {
            "description": "未授权",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "403": {
            "description": "响应不属于该用户",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "404": {
            "description": "消息或轮次不存在",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "503": {
            "description": "MySQL 未启用或不可用",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          }
        }
      }
    },
    "/api/chat/favorites/{favorite_id}": {
      "get": {
        "tags": ["sql_favorites"],
        "summary": "查询收藏详情（含 SQL 正文）",
        "description": "favorite_id 支持内部数字 id 或 favorite_uid。返回收藏摘要及关联的全部 chat_sql_execution（含 sql_content）。可选 Header X-Hermes-User-Id 做归属校验。",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "favorite_id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "收藏 id（数字）或 favorite_uid"
          },
          {
            "name": "X-Hermes-User-Id",
            "in": "header",
            "required": false,
            "type": "string",
            "description": "传入时校验收藏是否属于该用户"
          }
        ],
        "responses": {
          "200": {
            "description": "收藏详情",
            "schema": {"$ref": "#/definitions/ChatFavoriteDetailResponse"},
            "examples": {
              "application/json": {
                "object": "chat.sql_favorite",
                "favorite": {
                  "id": 1,
                  "favorite_uid": "a1b2c3d4e5f6789012345678901234567",
                  "followup_hermes_session_id": "sess_followup_xyz",
                  "sql_count": 1
                },
                "total": 1,
                "sql": [
                  {
                    "sql_content": "SELECT channel, COUNT(*) AS cnt FROM orders WHERE dt = '2026-05-16' GROUP BY channel",
                    "database": "analytics",
                    "instance": "prod-mysql-01",
                    "status": "success"
                  }
                ]
              }
            }
          },
          "401": {"description": "未授权", "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}},
          "403": {"description": "收藏不属于该用户", "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}},
          "404": {"description": "收藏不存在", "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}},
          "503": {"description": "MySQL 未启用或不可用", "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}}
        }
      }
    },
    "/api/chat/users/{user_id}/favorites": {
      "get": {
        "tags": ["sql_favorites"],
        "summary": "查询用户收藏列表",
        "description": "按 created_at 倒序分页返回收藏摘要（含 question_summary / answer_summary、sql_count、followup_hermes_session_id；不含 SQL 正文，详情见 GET /api/chat/favorites/{favorite_id}）。",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "业务用户 ID"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 20,
            "minimum": 1,
            "maximum": 100,
            "description": "每页条数"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 1,
            "minimum": 1,
            "description": "页码（从 1 开始）"
          }
        ],
        "responses": {
          "200": {
            "description": "收藏列表",
            "schema": {"$ref": "#/definitions/ChatUserFavoritesResponse"},
            "examples": {
              "application/json": {
                "object": "list",
                "user_id": "10001",
                "total": 1,
                "limit": 20,
                "page": 1,
                "favorites": [
                  {
                    "id": 1,
                    "favorite_uid": "a1b2c3d4e5f6789012345678901234567",
                    "user_id": "10001",
                    "hermes_response_id": "resp_abc123",
                    "question_summary": "查询昨日订单总量",
                    "answer_summary": "返回按渠道汇总的订单数与金额",
                    "fulfillment_status": "satisfied",
                    "sql_count": 2,
                    "followup_hermes_session_id": "sess_followup_xyz",
                    "created_at": "2026-05-17T10:30:00"
                  }
                ]
              }
            }
          },
          "401": {
            "description": "未授权",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "503": {
            "description": "MySQL 未启用或不可用",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          }
        }
      }
    },
    "/api/chat/favorites/{favorite_id}/sql": {
      "get": {
        "tags": ["sql_favorites"],
        "summary": "查询收藏下的 SQL 详情",
        "description": "favorite_id 支持内部数字 id 或 favorite_uid。返回该收藏关联的全部 chat_sql_execution（sql_content、database、instance 等）。可选 Header X-Hermes-User-Id 做归属校验。",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "favorite_id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "收藏 id（数字）或 favorite_uid"
          },
          {
            "name": "X-Hermes-User-Id",
            "in": "header",
            "required": false,
            "type": "string",
            "description": "传入时校验收藏是否属于该用户"
          }
        ],
        "responses": {
          "200": {
            "description": "SQL 列表",
            "schema": {"$ref": "#/definitions/ChatFavoriteSqlResponse"},
            "examples": {
              "application/json": {
                "object": "list",
                "favorite": {
                  "id": 1,
                  "favorite_uid": "a1b2c3d4e5f6789012345678901234567",
                  "hermes_response_id": "resp_abc123",
                  "sql_count": 1
                },
                "total": 1,
                "sql": [
                  {
                    "sql_content": "SELECT channel, COUNT(*) AS cnt FROM orders WHERE dt = '2026-05-16' GROUP BY channel",
                    "database": "analytics",
                    "instance": "prod-mysql-01",
                    "status": "success",
                    "executed_at": "2026-05-17T10:29:50",
                    "query_time_ms": 120.5,
                    "row_count": 4
                  }
                ]
              }
            }
          },
          "401": {
            "description": "未授权",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "403": {
            "description": "收藏不属于该用户",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "404": {
            "description": "收藏不存在",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "503": {
            "description": "MySQL 未启用或不可用",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          }
        }
      }
    }
  },
  "definitions": {
    "OpenAIErrorEnvelope": {
      "type": "object",
      "properties": {
        "error": {
          "type": "object",
          "properties": {
            "message": {"type": "string"},
            "type": {"type": "string"}
          }
        }
      }
    },
    "CreateSqlFavoriteRequest": {
      "type": "object",
      "required": ["hermes_response_id"],
      "properties": {
        "hermes_response_id": {
          "type": "string",
          "description": "助手回复 ID。兼容 /v1/responses 返回的 response.id、对话轮次接口返回的 hermes_response_id，或 chat_message.id 主键；传主键时后端会解析为对应的 chat_message.hermes_response_id。",
          "example": "resp_abc123"
        },
        "user_id": {
          "type": "string",
          "description": "业务用户 ID；未传 X-Hermes-User-Id 时必填",
          "example": "10001"
        }
      }
    },
    "ChatSqlFavoriteSummary": {
      "type": "object",
      "properties": {
        "id": {"type": "integer", "format": "int64", "description": "内部主键"},
        "favorite_uid": {"type": "string", "description": "对外收藏 ID"},
        "user_id": {"type": "string"},
        "session_id": {"type": "integer", "format": "int64"},
        "session_uid": {"type": "string"},
        "hermes_session_id": {"type": "string"},
        "turn_id": {"type": "integer", "format": "int64"},
        "turn_no": {"type": "integer"},
        "hermes_response_id": {"type": "string"},
        "followup_hermes_session_id": {
          "type": "string",
          "description": "基于该收藏续聊时最近一次使用的 Hermes session_id；续聊请带 X-Hermes-Session-Id"
        },
        "question_summary": {
          "type": "string",
          "description": "用户问题的 AI 摘要（非原文）"
        },
        "answer_summary": {
          "type": "string",
          "description": "助手回答的 AI 摘要（非原文）"
        },
        "fulfillment_status": {
          "type": "string",
          "enum": ["satisfied", "partial", "unsatisfied", "unknown"]
        },
        "fulfillment_reason": {"type": "string"},
        "sql_count": {"type": "integer", "description": "该收藏关联的 SQL 条数"},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"}
      }
    },
    "CreateSqlFavoriteResponse": {
      "type": "object",
      "properties": {
        "object": {"type": "string", "example": "chat.sql_favorite"},
        "created": {
          "type": "boolean",
          "description": "true=本次新建，false=已存在（幂等）"
        },
        "favorite": {"$ref": "#/definitions/ChatSqlFavoriteSummary"}
      }
    },
    "ChatUserFavoritesResponse": {
      "type": "object",
      "properties": {
        "object": {"type": "string", "example": "list"},
        "user_id": {"type": "string"},
        "total": {"type": "integer"},
        "limit": {"type": "integer"},
        "page": {"type": "integer", "minimum": 1},
        "favorites": {
          "type": "array",
          "items": {"$ref": "#/definitions/ChatSqlFavoriteSummary"}
        }
      }
    },
    "ChatSqlExecutionItem": {
      "type": "object",
      "properties": {
        "sql_content": {"type": "string"},
        "database": {"type": "string", "description": "库名（db_name）"},
        "instance": {"type": "string", "description": "实例名（instance_name）"},
        "status": {"type": "string", "enum": ["success", "error"]},
        "tool_call_id": {"type": "string"},
        "executed_at": {"type": "string", "format": "date-time"},
        "error_message": {"type": "string"},
        "query_time_ms": {"type": "number"},
        "row_count": {"type": "integer"}
      }
    },
    "ChatFavoriteSqlResponse": {
      "type": "object",
      "properties": {
        "object": {"type": "string", "example": "list"},
        "favorite": {"$ref": "#/definitions/ChatSqlFavoriteSummary"},
        "total": {"type": "integer"},
        "sql": {
          "type": "array",
          "items": {"$ref": "#/definitions/ChatSqlExecutionItem"}
        }
      }
    },
    "ChatFavoriteDetailResponse": {
      "type": "object",
      "properties": {
        "object": {"type": "string", "example": "chat.sql_favorite"},
        "favorite": {"$ref": "#/definitions/ChatSqlFavoriteSummary"},
        "total": {"type": "integer"},
        "sql": {
          "type": "array",
          "items": {"$ref": "#/definitions/ChatSqlExecutionItem"}
        }
      }
    }
  }
}

    {
      "name": "Chat History API (MySQL)",
      "description": "MySQL 落库后的会话与对话轮次查询。需启用 mysql_chat / HERMES_MYSQL_*。",
      "item": [
        {
          "name": "GET /api/chat/users/{user_id}/sessions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/chat/users/{{userId}}/sessions?limit=20&page=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chat",
                "users",
                "{{userId}}",
                "sessions"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20",
                  "description": "每页条数，默认 20，最大 100"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "页码，从 1 开始，默认 1"
                }
              ]
            },
            "description": "用途: 按业务用户 ID 查询会话列表（按 updated_at 倒序）。\n\n入参:\n- Path: user_id (string)\n- Query: limit (可选, 1-100, 默认 20)\n- Query: page (可选, 从 1 开始, 默认 1)\n\n出参(200):\n- object: \"list\"\n- user_id: string\n- total: number\n- limit: number\n- page: number\n- sessions: array\n  - id, session_uid, hermes_session_id, user_id, channel, status\n  - turn_count, last_question\n  - started_at, updated_at, created_at\n\n出参(503): MySQL 未启用或不可用"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"object\": \"list\",\n  \"user_id\": \"10001\",\n  \"total\": 1,\n  \"limit\": 20,\n  \"page\": 1,\n  \"sessions\": [\n    {\n      \"id\": 1,\n      \"session_uid\": \"a1b2c3d4e5f6...\",\n      \"hermes_session_id\": \"sess_abc123\",\n      \"user_id\": \"10001\",\n      \"channel\": \"api_server\",\n      \"status\": 1,\n      \"turn_count\": 3,\n      \"last_question\": \"最近一条用户问题\",\n      \"started_at\": \"2026-05-17T10:00:00\",\n      \"updated_at\": \"2026-05-17T10:30:00\"\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "GET /api/chat/sessions/{session_id}/turns",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/chat/sessions/{{sessionId}}/turns",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chat",
                "sessions",
                "{{sessionId}}",
                "turns"
              ]

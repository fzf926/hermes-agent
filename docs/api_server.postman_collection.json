    {
      "name": "Runs API",
      "item": [
        {
          "name": "POST /v1/runs",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Hermes-Session-Key",
                "value": "tenant:user:channel",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"hermes-agent\",\n  \"input\": \"帮我规划下周项目推进\",\n  \"instructions\": \"输出分点计划\",\n  \"conversation_history\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"我们是一个 3 人团队\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/runs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "runs"
              ]
            },
            "description": "用途: 异步启动一次 run，立即返回 run_id。\n\n主要入参:\n- input: string | message[] (required)\n- instructions: string (optional)\n- previous_response_id / conversation_history / session_id (optional)\n\n出参:\n- 202: {run_id, status: \"started\"}\n- 429: 并发超限"
          },
          "response": [
            {
              "name": "202 Accepted",
              "status": "Accepted",
              "code": 202,
              "body": "{\n  \"run_id\": \"run_4e1a58a2c8f84b8fa8f7d7d4e7bbf9c1\",\n  \"status\": \"started\"\n}"
            }
          ]
        },
        {
          "name": "GET /v1/runs/{run_id}",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/runs/{{runId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "runs",
                "{{runId}}"
              ]
            },
            "description": "用途: 查询 run 状态（轮询）。\n\n入参:\n- Path: run_id\n\n出参:\n- 200: status 对象（queued/running/waiting_for_approval/completed/failed/cancelled 等）\n- 404: run 不存在"
          }
        },
        {
          "name": "GET /v1/runs/{run_id}/events (SSE)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/runs/{{runId}}/events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "runs",
                "{{runId}}",
                "events"
              ]
            },
            "description": "用途: 订阅 run 生命周期事件（SSE）。\n\n入参:\n- Path: run_id\n\n出参:\n- Content-Type: text/event-stream\n- data: {event, run_id, timestamp, ...}\n- 心跳: `: keepalive`\n- 结束: `: stream closed`"
          }
        },
        {
          "name": "POST /v1/runs/{run_id}/approval",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"choice\": \"once\",\n  \"all\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/runs/{{runId}}/approval",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "runs",
                "{{runId}}",
                "approval"
              ]
            },
            "description": "用途: 响应 run 的审批请求。\n\n入参:\n- choice: once | session | always | deny（也支持 approve/approved/allow 别名）\n- all 或 resolve_all: boolean (可选)\n\n出参:\n- 200: {object, run_id, choice, resolved}\n- 409: 没有活动审批会话或无待审批项"
          }
        },
        {
          "name": "POST /v1/runs/{run_id}/stop",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/runs/{{runId}}/stop",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "runs",
                "{{runId}}",
                "stop"
              ]
            },
            "description": "用途: 中断正在执行的 run。\n\n入参:\n- Path: run_id\n\n出参:\n- 200: {run_id, status: \"stopping\"}\n- 404: run 不存在"
          }
        }
      ]
    },

    {
      "name": "OpenAI Chat & Responses",
      "item": [
        {
          "name": "POST /v1/chat/completions (non-stream)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Hermes-Session-Id",
                "value": "{{sessionId}}",
                "disabled": true
              },
              {
                "key": "X-Hermes-Session-Key",
                "value": "tenant:user:channel",
                "disabled": true
              },
              {
                "key": "Idempotency-Key",
                "value": "chat-demo-key-001",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"hermes-agent\",\n  \"stream\": false,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are Hermes.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"请总结一下今天的待办\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/chat/completions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "chat",
                "completions"
              ]
            },
            "description": "用途: OpenAI Chat Completions 兼容接口。\n\n主要入参:\n- model: string\n- messages: array (required)\n- stream: boolean (默认 false)\n- 可选 Header: X-Hermes-Session-Id / X-Hermes-Session-Key / Idempotency-Key\n\n主要出参(200, JSON):\n- id/object/created/model\n- choices[].message.role/content\n- choices[].finish_reason\n- usage.input_tokens/output_tokens/total_tokens\n- Header: X-Hermes-Session-Id (总会返回), X-Hermes-Session-Key (如果有)"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": \"chatcmpl-abc123\",\n  \"object\": \"chat.completion\",\n  \"created\": 1778920000,\n  \"model\": \"hermes-agent\",\n  \"choices\": [\n    {\n      \"index\": 0,\n      \"message\": {\n        \"role\": \"assistant\",\n        \"content\": \"这是你的待办总结...\"\n      },\n      \"finish_reason\": \"stop\"\n    }\n  ],\n  \"usage\": {\n    \"input_tokens\": 123,\n    \"output_tokens\": 45,\n    \"total_tokens\": 168\n  }\n}"
            },
            {
              "name": "400 Bad Request",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": {\n    \"message\": \"Missing or invalid 'messages' field\",\n    \"type\": \"invalid_request_error\"\n  }\n}"
            }
          ]
        },
        {
          "name": "POST /v1/chat/completions (stream=true, SSE)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"hermes-agent\",\n  \"stream\": true,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"逐步解释一下 HTTP keepalive\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/chat/completions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "chat",
                "completions"
              ]
            },
            "description": "用途: Chat Completions 流式输出。\n\n入参关键点:\n- stream 必须为 true\n\n出参:\n- Content-Type: text/event-stream\n- SSE `data:` 事件包含增量文本与工具生命周期事件\n- 末尾会发送 `[DONE]`\n\nPostman 使用建议:\n- 直接发送可看到原始 SSE 流；如需持续观察，建议在 Postman Console 查看。"
          },
          "response": [
            {
              "name": "200 SSE",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "text/event-stream"
                }
              ],
              "body": "data: {\"id\":\"chatcmpl-abc\",\"object\":\"chat.completion.chunk\",\"choices\":[{\"delta\":{\"content\":\"HTTP \"}}]}\n\ndata: {\"id\":\"chatcmpl-abc\",\"object\":\"chat.completion.chunk\",\"choices\":[{\"delta\":{\"content\":\"keepalive\"}}]}\n\ndata: [DONE]\n"
            }
          ]
        },
        {
          "name": "POST /v1/responses (non-stream)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Hermes-Session-Key",
                "value": "tenant:user:channel",
                "disabled": true
              },
              {
                "key": "Idempotency-Key",
                "value": "resp-demo-key-001",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"hermes-agent\",\n  \"input\": \"帮我写一个简单的发布公告\",\n  \"instructions\": \"语气正式、简洁\",\n  \"stream\": false,\n  \"store\": true,\n  \"conversation\": \"release-announcement-demo\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/responses",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "responses"
              ]
            },
            "description": "用途: OpenAI Responses API 兼容接口。\n\n主要入参:\n- input: string | message[] (required)\n- instructions: string (optional)\n- previous_response_id / conversation / conversation_history (可选)\n- store: boolean (默认 true)\n- stream: boolean (默认 false)\n\n主要出参(200, JSON):\n- id/object/status/created_at/model\n- output[]\n- usage.input_tokens/output_tokens/total_tokens\n- Header: X-Hermes-Session-Id, X-Hermes-Session-Key(如有)"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": \"resp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx\",\n  \"object\": \"response\",\n  \"status\": \"completed\",\n  \"created_at\": 1778920000,\n  \"model\": \"hermes-agent\",\n  \"output\": [\n    {\n      \"id\": \"msg_1\",\n      \"type\": \"message\",\n      \"role\": \"assistant\",\n      \"content\": [\n        {\n          \"type\": \"output_text\",\n          \"text\": \"以下是发布公告...\"\n        }\n      ]\n    }\n  ],\n  \"usage\": {\n    \"input_tokens\": 120,\n    \"output_tokens\": 60,\n    \"total_tokens\": 180\n  }\n}"
            },
            {
              "name": "404 Previous response not found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"error\": {\n    \"message\": \"Previous response not found: resp_not_exists\",\n    \"type\": \"invalid_request_error\"\n  }\n}"
            }
          ]
        },
        {
          "name": "POST /v1/responses (stream=true, SSE)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"hermes-agent\",\n  \"input\": \"帮我写一份会议纪要模板\",\n  \"stream\": true,\n  \"store\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/responses",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "responses"
              ]
            },
            "description": "用途: Responses API 流式输出。\n\n入参关键点:\n- stream=true\n\n出参:\n- Content-Type: text/event-stream\n- SSE 事件包含 `response.created`、`response.output_text.delta`、`response.completed` 等（取决于执行过程）"
          },
          "response": [
            {
              "name": "200 SSE",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "text/event-stream"
                }
              ],
              "body": "event: response.created\ndata: {\"id\":\"resp_xxx\",\"status\":\"in_progress\"}\n\nevent: response.output_text.delta\ndata: {\"delta\":\"会议纪要模板\"}\n\nevent: response.completed\ndata: {\"id\":\"resp_xxx\",\"status\":\"completed\"}\n\n"
            }
          ]
        }
      ]
    },

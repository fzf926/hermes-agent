{
  "swagger": "2.0",
  "info": {
    "title": "Hermes Chat History API",
    "description": "MySQL 聊天记录与 SQL 收藏接口。来源: gateway/platforms/api_server.py + gateway/chat_mysql_store.py",
    "version": "1.0.0"
  },
  "host": "127.0.0.1:8642",
  "basePath": "/",
  "schemes": ["http"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Format: Bearer <API_SERVER_KEY>"
    }
  },
  "tags": [
    {
      "name": "chat_history",
      "description": "MySQL-backed chat session, turn, and SQL favorite queries"
    }
  ],
  "paths": {
    "/api/chat/users/{user_id}/sessions": {
      "get": {
        "tags": ["chat_history"],
        "summary": "List chat sessions by user",
        "description": "Returns sessions for a business user_id, ordered by updated_at descending. Requires mysql_chat / HERMES_MYSQL_* enabled.",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Business user identifier"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 20,
            "minimum": 1,
            "maximum": 100
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 1,
            "minimum": 1,
            "description": "Page number (1-based)"
          },
          {
            "name": "conversation_type",
            "in": "query",
            "required": false,
            "type": "string",
            "description": "Filter by conversation type. Comma-separated: 1=history, 2=favorite, 3=direct SQL. Default 1,3 (normal history + direct SQL; excludes favorite sessions)."
          }
        ],
        "responses": {
          "200": {
            "description": "Session list",
            "schema": {"$ref": "#/definitions/ChatUserSessionsResponse"},
            "examples": {
              "application/json": {
                "object": "list",
                "user_id": "10001",
                "total": 1,
                "limit": 20,
                "page": 1,
                "conversation_types": [1, 3],
                "sessions": [
                  {
                    "id": 1,
                    "session_uid": "a1b2c3d4e5f6789012345678901234567",
                    "hermes_session_id": "sess_abc123",
                    "user_id": "10001",
                    "channel": "api_server",
                    "conversation_type": 1,
                    "status": 1,
                    "turn_count": 3,
                    "last_question": "最近一条用户问题",
                    "updated_at": "2026-05-17T10:30:00"
                  }
                ]
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "503": {
            "description": "MySQL chat store disabled or unavailable",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          }
        }
      }
    },
    "/api/chat/sessions/{session_id}/turns": {
      "get": {
        "tags": ["chat_history"],
        "summary": "List Q&A turns by session",
        "description": "Returns Q&A turns ordered by turn_no ascending. session_id: internal id, session_uid, or hermes_session_id.",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Internal id, session_uid, or hermes_session_id"
          }
        ],
        "responses": {
          "200": {
            "description": "Turn list",
            "schema": {"$ref": "#/definitions/ChatSessionTurnsResponse"},
            "examples": {
              "application/json": {
                "object": "list",
                "session": {
                  "id": 1,
                  "hermes_session_id": "sess_abc123",
                  "user_id": "10001"
                },
                "total": 2,
                "turns": [
                  {
                    "turn_no": 1,
                    "question_text": "你好",
                    "answer_text": "你好，我是 Hermes",
                    "status": "answered"
                  },
                  {
                    "turn_no": 2,
                    "question_text": "第二条问题",
                    "answer_text": "第二条回答",
                    "status": "answered"
                  }
                ]
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "404": {
            "description": "Session not found",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "503": {
            "description": "MySQL chat store disabled or unavailable",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          }
        }
      }
    },
    "/api/chat/favorites": {
      "post": {
        "tags": ["chat_history"],
        "summary": "Favorite SQL from a satisfied turn",
        "description": "Bookmarks all chat_sql_execution rows for the turn identified by hermes_response_id. Only fulfillment_status=satisfied is allowed. Stores AI-generated question_summary and answer_summary (not full text). Idempotent per user+response.",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "X-Hermes-User-Id",
            "in": "header",
            "required": false,
            "type": "string",
            "description": "Business user id (or pass body.user_id)"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/CreateSqlFavoriteRequest"}
          }
        ],
        "responses": {
          "201": {
            "description": "Favorite created",
            "schema": {"$ref": "#/definitions/CreateSqlFavoriteResponse"}
          },
          "200": {
            "description": "Favorite already exists",
            "schema": {"$ref": "#/definitions/CreateSqlFavoriteResponse"}
          },
          "400": {
            "description": "Not satisfied or no SQL",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "403": {
            "description": "Response belongs to another user",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "404": {
            "description": "Message or turn not found",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          }
        }
      }
    },
    "/api/chat/users/{user_id}/favorites": {
      "get": {
        "tags": ["chat_history"],
        "summary": "List SQL favorites by user",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 20,
            "minimum": 1,
            "maximum": 100
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 1,
            "minimum": 1
          }
        ],
        "responses": {
          "200": {
            "description": "Favorite list",
            "schema": {"$ref": "#/definitions/ChatUserFavoritesResponse"}
          }
        }
      }
    },
    "/api/chat/favorites/{favorite_id}/sql": {
      "get": {
        "tags": ["chat_history"],
        "summary": "List SQL executions for a favorite",
        "description": "favorite_id: internal id or favorite_uid",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "favorite_id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "X-Hermes-User-Id",
            "in": "header",
            "required": false,
            "type": "string",
            "description": "Optional ownership check"
          }
        ],
        "responses": {
          "200": {
            "description": "SQL list",
            "schema": {"$ref": "#/definitions/ChatFavoriteSqlResponse"}
          },
          "403": {
            "description": "Favorite belongs to another user",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          },
          "404": {
            "description": "Favorite not found",
            "schema": {"$ref": "#/definitions/OpenAIErrorEnvelope"}
          }
        }
      }
    }
  },
  "definitions": {
    "OpenAIErrorEnvelope": {
      "type": "object",
      "properties": {
        "error": {
          "type": "object",
          "properties": {
            "message": {"type": "string"},
            "type": {"type": "string"}
          }
        }
      }
    },
    "ChatSessionSummary": {
      "type": "object",
      "properties": {
        "id": {"type": "integer", "format": "int64"},
        "session_uid": {"type": "string"},
        "hermes_session_id": {"type": "string"},
        "user_id": {"type": "string"},
        "tenant_id": {"type": "string"},
        "channel": {"type": "string", "example": "api_server"},
        "conversation_type": {
          "type": "integer",
          "description": "1=history, 2=favorite, 3=direct SQL"
        },
        "title": {"type": "string"},
        "status": {"type": "integer", "description": "1=active, 2=closed, 3=archived"},
        "started_at": {"type": "string", "format": "date-time"},
        "ended_at": {"type": "string", "format": "date-time"},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"},
        "turn_count": {"type": "integer"},
        "last_question": {"type": "string"}
      }
    },
    "ChatTurnItem": {
      "type": "object",
      "properties": {
        "id": {"type": "integer", "format": "int64"},
        "session_id": {"type": "integer", "format": "int64"},
        "user_id": {"type": "string"},
        "turn_no": {"type": "integer"},
        "question_message_id": {"type": "integer", "format": "int64"},
        "answer_message_id": {"type": "integer", "format": "int64"},
        "question_text": {"type": "string"},
        "answer_text": {"type": "string"},
        "status": {
          "type": "string",
          "enum": ["answered", "timeout", "error", "interrupted"]
        },
        "error_code": {"type": "string"},
        "error_message": {"type": "string"},
        "feedback_score": {"type": "integer"},
        "created_at": {"type": "string", "format": "date-time"},
        "sql": {
          "type": "array",
          "items": {"$ref": "#/definitions/ChatSqlExecutionItem"}
        },
        "sql_display": {
          "type": "string",
          "description": "Merged markdown for all SQL executions on this turn (same as /v1/responses)"
        },
        "conversation": {"$ref": "#/definitions/ChatConversationFulfillment"}
      }
    },
    "ChatConversationFulfillment": {
      "type": "object",
      "description": "LLM judge result for whether the turn satisfied user intent",
      "properties": {
        "fulfillment_status": {
          "type": "string",
          "enum": ["satisfied", "partial", "unsatisfied", "unknown"]
        },
        "fulfillment_reason": {"type": "string"},
        "is_final": {"type": "boolean"}
      }
    },
    "ChatSqlExecutionItem": {
      "type": "object",
      "properties": {
        "sql_content": {"type": "string"},
        "database": {"type": "string"},
        "instance": {"type": "string"},
        "status": {"type": "string", "enum": ["success", "error"]},
        "tool_call_id": {"type": "string"},
        "executed_at": {"type": "string", "format": "date-time"},
        "error_message": {"type": "string"},
        "query_time_ms": {"type": "number"},
        "row_count": {"type": "integer"},
        "total_row_count": {"type": "integer"},
        "delivery_mode": {
          "type": "string",
          "enum": ["inline", "excel", "dbops_export", "sql_only"]
        },
        "download_url": {"type": "string"},
        "generation_reason": {"type": "string"},
        "export_uid": {"type": "string"},
        "dbops_export_task_id": {"type": "string"},
        "result_table": {
          "type": "string",
          "description": "Markdown table: column headers + all rows merged"
        },
        "user_display": {
          "type": "string",
          "description": "User-facing markdown block (metadata + result_table) for one SQL execution"
        }
      }
    },
    "ChatUserSessionsResponse": {
      "type": "object",
      "properties": {
        "object": {"type": "string", "example": "list"},
        "user_id": {"type": "string"},
        "total": {"type": "integer"},
        "limit": {"type": "integer"},
        "page": {"type": "integer", "minimum": 1, "example": 1},
        "conversation_types": {
          "type": "array",
          "items": {"type": "integer"},
          "description": "Applied filter (echo of query conversation_type)"
        },
        "sessions": {
          "type": "array",
          "items": {"$ref": "#/definitions/ChatSessionSummary"}
        }
      }
    },
    "ChatSessionTurnsResponse": {
      "type": "object",
      "properties": {
        "object": {"type": "string", "example": "list"},
        "session": {"$ref": "#/definitions/ChatSessionSummary"},
        "total": {"type": "integer"},
        "turns": {
          "type": "array",
          "items": {"$ref": "#/definitions/ChatTurnItem"}
        }
      }
    },
    "CreateSqlFavoriteRequest": {
      "type": "object",
      "required": ["hermes_response_id"],
      "properties": {
        "hermes_response_id": {
          "type": "string",
          "description": "Assistant response id from /v1/responses"
        },
        "user_id": {
          "type": "string",
          "description": "Optional if X-Hermes-User-Id header is set"
        }
      }
    },
    "ChatSqlFavoriteSummary": {
      "type": "object",
      "properties": {
        "id": {"type": "integer", "format": "int64"},
        "favorite_uid": {"type": "string"},
        "user_id": {"type": "string"},
        "session_id": {"type": "integer", "format": "int64"},
        "session_uid": {"type": "string"},
        "hermes_session_id": {"type": "string"},
        "turn_id": {"type": "integer", "format": "int64"},
        "turn_no": {"type": "integer"},
        "hermes_response_id": {"type": "string"},
        "question_summary": {
          "type": "string",
          "description": "AI-generated short summary of the user question"
        },
        "answer_summary": {
          "type": "string",
          "description": "AI-generated short summary of the assistant answer"
        },
        "fulfillment_status": {"type": "string"},
        "fulfillment_reason": {"type": "string"},
        "sql_count": {"type": "integer"},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"}
      }
    },
    "CreateSqlFavoriteResponse": {
      "type": "object",
      "properties": {
        "object": {"type": "string", "example": "chat.sql_favorite"},
        "created": {"type": "boolean"},
        "favorite": {"$ref": "#/definitions/ChatSqlFavoriteSummary"}
      }
    },
    "ChatUserFavoritesResponse": {
      "type": "object",
      "properties": {
        "object": {"type": "string", "example": "list"},
        "user_id": {"type": "string"},
        "total": {"type": "integer"},
        "limit": {"type": "integer"},
        "page": {"type": "integer"},
        "favorites": {
          "type": "array",
          "items": {"$ref": "#/definitions/ChatSqlFavoriteSummary"}
        }
      }
    },
    "ChatFavoriteSqlResponse": {
      "type": "object",
      "properties": {
        "object": {"type": "string", "example": "list"},
        "favorite": {"$ref": "#/definitions/ChatSqlFavoriteSummary"},
        "total": {"type": "integer"},
        "sql": {
          "type": "array",
          "items": {"$ref": "#/definitions/ChatSqlExecutionItem"}
        }
      }
    }
  }
}
